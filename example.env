# Copie este arquivo para .env e preencha os valores.

# ── DeepInfra ────────────────────────────────────────────────────────────────
DEEPINFRA_API_KEY=di_...                # OBRIGATÓRIO

# Modelos (configuração de cost/performance)
COORDINATOR_MODEL_ID=zai-org/GLM-5.2
SPECIALIST_MODEL_ID=deepseek-ai/DeepSeek-V3-0324

# ── Banco de dados (sessão/tracing do AgentOS) ───────────────────────────────
DB_URL=postgresql+psycopg://banco:agil_dev_pw@localhost:5432/banco_agil

# ── AgentOS ─────────────────────────────────────────────────────────────────
AGENTOS_URL=http://localhost:8000
AGENTOS_API_KEY=dev-key

# Necessária apenas em produção (Railway), para conectar o os.agno.com em
# modo "Live". Gere o par de chaves com scripts/generate_jwt_keys.sh e cole
# aqui o conteúdo de keys/jwt_public.pem.
# JWT_VERIFICATION_KEY=-----BEGIN PUBLIC KEY-----...

# ── API de Câmbio (AwesomeAPI) ───────────────────────────────────────────────
# Opcional — sem token funciona com cache de 1min e rate limit baixo. Com
# token grátis (https://docs.awesomeapi.com.br/instrucoes-api-key), sobe
# para 100k requisições/mês.
# AWESOMEAPI_TOKEN=...

# ── Aplicação ───────────────────────────────────────────────────────────────
APP_ENV=dev                # dev | staging | production
LOG_LEVEL=DEBUG             # DEBUG | INFO | WARNING | ERROR
AGNO_TELEMETRY=false
